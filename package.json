{
  "name": "udaman",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev -p 3008 --turbopack",
    "build": "bun --bun next build",
    "start": "bun --bun next start -p 3008",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "check-types": "tsc --noEmit",
    "db:generate": "prisma generate --schema src/core/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/core/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema src/core/database/prisma/schema.prisma",
    "console": "bun run src/core/scripts/console.ts",
    "worker": "bun run src/core/workers/worker.ts",
    "scraper": "bun run src/core/workers/scrape-runner.ts",
    "qpub": "bun run src/core/workers/qpub-cli.ts"
  },
  "dependencies": {
