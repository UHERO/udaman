    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "d3-array": "^3.2.4",
    "date-fns": "^4.2.1",
    "file-saver": "^2.0.5",
    "jspdf-autotable": "^5.0.8",
