{
  "manifest_version": 3,
  "name": "QPub Scraper",
  "version": "1.0.0",
  "description": "Scrape QPub property pages and download HTML files",
  "permissions": ["downloads", "storage", "alarms"],
  "host_permissions": [
    "https://qpublic.schneidercorp.com/*",
    "http://localhost:3008/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://qpublic.schneidercorp.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
